{
  "appId": "com.proxypress.app",
  "appName": "Proxy-Press",
  "webDir": "out",
  "server": {
    "url": "https://proxy-press-omega.vercel.app",
    "cleartext": true,
    "allowNavigation": [
      "proxy-press-omega.vercel.app"
    ]
  },
  "android": {
    "backgroundColor": "#ffffff"
  },
  "ios": {
    "contentInset": "always"
  },
  "plugins": {
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  }
}
